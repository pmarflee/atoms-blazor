@inherits UserNameComponent

<FluentTextField Name="Input.Name"
                 @bind-Value=@Name
                 Label="Name"
                 Required
                 Autofocus
                 Placeholder="Please enter your name"
                 Minlength="3"
                 Maxlength="25"
                 Pattern="^[A-Za-z0-9]([A-Za-z0-9_ ]*[A-Za-z0-9])?$"
                 Title="Username can only contain letters, numbers, spaces, underscores and dashes, and must start and end with a letter or number"
                 AutoComplete="name"
                 Style="width: 100%;" />
