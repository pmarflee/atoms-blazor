@inherits PasswordResetCodeComponent

<EmailLayout Title="Reset Your Password" 
             FromAddress="@FromAddress" 
             LogoUrl="@LogoUrl">
    <p>Hello @UserName,</p>
    <p>We received a request to reset your password. Use the code below to reset it:</p>
    <div style="background-color: #f8f9fa; border: 1px solid #dee2e6; border-radius: 4px; padding: 20px; margin: 30px 0; text-align: center;">
        <code style="font-size: 24px; font-weight: bold; letter-spacing: 4px; color: #333;">@ResetCode</code>
    </div>
    <p>If you didn't request a password reset, please ignore this email.</p>
</EmailLayout>
