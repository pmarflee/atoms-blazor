@inherits PasswordResetLinkComponent

<EmailLayout Title="Reset Your Password" 
             FromAddress="@FromAddress" 
             LogoUrl="@LogoUrl">
    <p>Hello @UserName,</p>
    <p>We received a request to reset your password. Click the button below to reset it:</p>
    <table cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0;">
        <tr>
            <td style="background-color: #dc3545; border-radius: 4px; padding: 12px 30px;">
                <a href="@ResetLink" style="color: white; text-decoration: none; font-weight: bold;">Reset Password</a>
            </td>
        </tr>
    </table>
    <p>If the button doesn't work, copy and paste this link into your browser:</p>
    <p><a href="@ResetLink">@ResetLink</a></p>
    <p>This link expires in 24 hours.</p>
    <p>If you didn't request a password reset, please ignore this email.</p>
</EmailLayout>
