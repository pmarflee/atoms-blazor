@inherits EmailConfirmationComponent

<EmailLayout Title="Confirm Your Email" 
             FromAddress="@FromAddress" 
             LogoHtml="@LogoHtml">
    <p>Hello @UserName,</p>
    <p>Thank you for registering with Atoms! Please confirm your email address by clicking the button below:</p>
    <table cellpadding="0" cellspacing="0" border="0" style="margin: 30px 0;">
        <tr>
            <td style="background-color: #007bff; border-radius: 4px; padding: 12px 30px;">
                <a href="@ConfirmationLink" style="color: white; text-decoration: none; font-weight: bold;">Confirm Email</a>
            </td>
        </tr>
    </table>
    <p>If the button doesn't work, copy and paste this link into your browser:</p>
    <p><a href="@ConfirmationLink">@ConfirmationLink</a></p>
    <p>This link expires in 24 hours.</p>
</EmailLayout>
